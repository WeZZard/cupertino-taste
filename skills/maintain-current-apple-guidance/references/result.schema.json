{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Current Apple guidance review result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "checked_on",
    "report_sha256",
    "source_assessments",
    "changes",
    "replacement_markdown",
    "blocked_reason",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "current",
        "updated",
        "blocked"
      ]
    },
    "checked_on": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "report_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "source_assessments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "normalized_sha256",
          "classification",
          "impact"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "normalized_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "classification": {
            "type": "string",
            "enum": [
              "supports_current_guidance",
              "guidance_gap",
              "editorial_only",
              "blocked"
            ]
          },
          "impact": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "section",
          "summary",
          "source_ids"
        ],
        "properties": {
          "section": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "source_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "replacement_markdown": {
      "type": "string"
    },
    "blocked_reason": {
      "type": "string"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    }
  }
}
